<div class="dropdown">
<button class="navbar-brand dropdown-toggle"
   type="button"
   data-bs-toggle="dropdown">
<%= image_tag "W-logo.png", class: "brand-logo" %>
</button>
<ul class="dropdown-menu">
<li>
  <%= link_to "Sign In", new_admin_session_path, class: "dropdown-item" %>
</li>
<% if admin_signed_in? %>
<li>
  <%= link_to "Sign Out", destroy_admin_session_path, data: { turbo_method: :delete }, class: "dropdown-item" %>
</li>
<% end %>
</ul>
</div>
